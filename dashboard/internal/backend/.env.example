# OmniEvaluator Internal Dashboard - Environment variables example
# Copy to .env and fill in values: cp .env.example .env

# === S3 (when using an S3 / S3-compatible source) ===
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET_NAME=your-bucket
# S3_PREFIX=your-prefix/
# S3_REGION=your-region
# S3_ENDPOINT_URL=https://your-s3-endpoint

# === Other ===
# OMNI_INTERNAL_OUTPUTS_PATH=/path/to/evaluator/outputs
# OMNI_INTERNAL_UPLOAD_DIR=/tmp/omni-internal-dashboard-uploads
